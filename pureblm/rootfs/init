#!/bin/sh
set -x

# Mount essential filesystems
mount -t proc proc /proc
mount -t sysfs sys /sys
mount -t devtmpfs dev /dev
mkdir -p /dev/pts
mount -t devpts devpts /dev/pts
mount -t tmpfs tmpfs /tmp -o exec,mode=1777

# Load kernel modules for ISO support
MOD_DIR=/lib/modules/6.6.134-0-virt/kernel
insmod $MOD_DIR/drivers/cdrom/cdrom.ko
insmod $MOD_DIR/drivers/scsi/sr_mod.ko
insmod $MOD_DIR/fs/isofs/isofs.ko

# Wait for devices to settle
sleep 2

# Mount the ISO/CD-ROM
mkdir -p /mnt/iso
mount -t iso9660 /dev/sr0 /mnt/iso || mount -t iso9660 /dev/cdrom /mnt/iso

# Set environment
export PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
export TERM=xterm-256color
export HOME=/root
mkdir -p /root

echo "PureBLM: Preparing Aligned BareMetalLlama Engine..."
BUNDLE="/mnt/iso/app/qwen2505b.baremetallama"

# Aligned Static Native ELF Offset
ENGINE_SIZE=15459920
MODEL_OFFSET=15462400

if [ -f "$BUNDLE" ]; then
    # 1. Extract ONLY the engine
    head -c $ENGINE_SIZE "$BUNDLE" > /tmp/baremetallama
    chmod +x /tmp/baremetallama
    
    # 2. Set the Bundle Environment Variables
    export BAREMETALLAMA_SOURCE="$BUNDLE"
    export BAREMETALLAMA_OFFSET="$MODEL_OFFSET"
    
    echo "PureBLM: Launching BareMetalLlama Dashboard..."
    # Launch on the main console. 
    # The isatty() patch in console.cpp will handle the rest.
    /tmp/baremetallama < /dev/console > /dev/console 2>&1
    
    echo "AI Engine exited with code $?"
else
    echo "Error: $BUNDLE not found on ISO!"
    ls -R /mnt/iso
fi

# Drop to shell for debugging
echo "Dropping to emergency shell."
sh
